<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Gato Aviador - WWI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@600&display=swap');
        
        body {
            margin: 0;
            overflow: hidden;
            background-color: #1a202c; /* Fondo oscuro fuera del canvas */
            font-family: 'Fredoka', sans-serif;
            touch-action: none; /* Prevenir scroll en móviles */
        }

        #game-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        canvas {
            background: linear-gradient(180deg, #60A5FA 0%, #93C5FD 100%);
            box-shadow: 0 0 20px rgba(0,0,0,0.5);
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .ui-layer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .hud {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            box-sizing: border-box;
            font-size: 24px;
            color: white;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
            pointer-events: none;
            z-index: 10;
        }

        .menu-box {
            background: rgba(255, 255, 255, 0.9);
            padding: 2rem 4rem;
            border-radius: 1rem;
            text-align: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
            pointer-events: auto;
            border: 4px solid #3B82F6;
        }

        button {
            background-color: #EF4444;
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 24px;
            border-radius: 50px;
            cursor: pointer;
            font-family: 'Fredoka', sans-serif;
            transition: transform 0.1s, background-color 0.2s;
            box-shadow: 0 6px 0 #B91C1C;
            margin-top: 20px;
        }

        button:active {
            transform: translateY(6px);
            box-shadow: 0 0 0 #B91C1C;
        }
        
        button:hover {
            background-color: #F87171;
        }

        .hidden { display: none !important; }
    </style>
</head>
<body>

<div id="game-container">
    <!-- El tamaño interno del canvas es fijo para mantener la lógica simple, 
         CSS se encarga de escalarlo a la pantalla -->
    <canvas id="gameCanvas" width="600" height="800"></canvas>

    <div class="hud hidden" id="hud">
        <div>Puntos: <span id="score">0</span></div>
        <div class="flex items-center">
            <svg width="30" height="30" viewBox="0 0 100 100" class="mr-2 inline">
                <path d="M50 90 C 20 90, 10 60, 10 40 C 10 20, 30 10, 50 30 C 70 10, 90 20, 90 40 C 90 60, 80 90, 50 90 Z" fill="#EF4444"/>
            </svg>
            <span id="lives">3</span>
        </div>
    </div>

    <div class="ui-layer" id="startScreen">
        <div class="menu-box">
            <h1 class="text-5xl text-blue-600 mb-2 font-bold">Gato Aviador</h1>
            <p class="text-gray-600 mb-6 text-xl">WWI Edición Felina</p>
            <p class="text-sm text-gray-500 mb-4">Mueve el ratón, usa las flechas<br>o arrastra el dedo para volar.</p>
            <button id="startBtn">¡A VOLAR!</button>
        </div>
    </div>

    <div class="ui-layer hidden" id="gameOverScreen">
        <div class="menu-box">
            <h1 class="text-5xl text-red-600 mb-2 font-bold">¡Derribado!</h1>
            <p class="text-gray-600 text-2xl mb-2">Puntos: <span id="finalScore" class="font-bold text-blue-600">0</span></p>
            <button id="restartBtn">REINTENTAR</button>
        </div>
    </div>
</div>

<script>
/**
 * GENERACIÓN DE ASSETS (Imágenes SVG)
 * Convertimos strings SVG a objetos Image para dibujarlos rápidamente en el Canvas.
 */
const createSvgImage = (svgString) => {
    const img = new Image();
    const encoded = encodeURIComponent(svgString);
    img.src = `data:image/svg+xml;charset=utf-8,${encoded}`;
    return img;
};

// SVG del Avión del Gato (Biplano Verde con Gatito Naranja)
const playerSvg = `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
    <!-- Hélice girando (efecto borroso) -->
    <ellipse cx="50" cy="5" rx="40" ry="5" fill="#e5e7eb" opacity="0.6"/>
    <!-- Ala superior -->
    <rect x="10" y="30" width="80" height="15" fill="#4d7c0f" rx="5"/>
    <rect x="10" y="30" width="80" height="4" fill="#65a30d" rx="2"/>
    <!-- Fuselaje -->
    <path d="M40 20 L60 20 L65 80 L50 95 L35 80 Z" fill="#3f6212"/>
    <path d="M40 20 L60 20 L60 80 L40 80 Z" fill="#4d7c0f"/>
    <!-- Cola -->
    <path d="M30 85 L70 85 L50 98 Z" fill="#3f6212"/>
    <!-- Gatito en la cabina -->
    <circle cx="50" cy="45" r="12" fill="#f97316"/> <!-- Cabeza -->
    <polygon points="42,35 45,45 38,45" fill="#f97316"/> <!-- Oreja izq -->
    <polygon points="58,35 55,45 62,45" fill="#f97316"/> <!-- Oreja der -->
    <rect x="42" y="42" width="16" height="6" fill="#1f2937" rx="3"/> <!-- Gafas -->
    <path d="M45 50 Q50 55 55 50" stroke="#9a3412" stroke-width="2" fill="none"/> <!-- Hocico -->
    <!-- Ala inferior (parcialmente oculta) -->
    <rect x="20" y="55" width="60" height="12" fill="#3f6212" rx="4"/>
    <circle cx="50" cy="5" r="4" fill="#1f2937"/> <!-- Eje hélice -->
</svg>`;

// SVG del Avión Enemigo (Biplano Rojo, Barón Rojo)
const enemySvg = `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
    <!-- Hélice abajo porque vuela hacia nosotros -->
    <ellipse cx="50" cy="95" rx="35" ry="5" fill="#e5e7eb" opacity="0.6"/>
    <!-- Cola arriba -->
    <path d="M35 15 L65 15 L50 5 Z" fill="#7f1d1d"/>
    <!-- Fuselaje -->
    <path d="M40 80 L60 80 L65 20 L50 10 L35 20 Z" fill="#b91c1c"/>
    <!-- Ala inferior -->
    <rect x="20" y="35" width="60" height="12" fill="#991b1b" rx="4"/>
    <!-- Ala superior -->
    <rect x="10" y="55" width="80" height="15" fill="#dc2626" rx="5"/>
    <rect x="10" y="55" width="80" height="4" fill="#ef4444" rx="2"/>
    <!-- Cruces negras (Insignia) -->
    <rect x="20" y="60" width="10" height="4" fill="#000"/>
    <rect x="23" y="57" width="4" height="10" fill="#000"/>
    <rect x="70" y="60" width="10" height="4" fill="#000"/>
    <rect x="73" y="57" width="4" height="10" fill="#000"/>
    <!-- Cabina -->
    <circle cx="50" cy="40" r="8" fill="#1f2937"/>
</svg>`;

// Misil Enemigo
const missileSvg = `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 60">
    <path d="M10 60 L5 50 L5 10 C5 5, 10 0, 10 0 C10 0, 15 5, 15 10 L15 50 Z" fill="#4b5563"/>
    <path d="M10 0 C10 0, 15 5, 15 10 L5 10 C5 5, 10 0, 10 0 Z" fill="#ef4444"/>
    <!-- Fuego -->
    <path d="M5 50 L10 60 L15 50 Q10 55 5 50 Z" fill="#f59e0b"/>
</svg>`;

const assets = {
    player: createSvgImage(playerSvg),
    enemy: createSvgImage(enemySvg),
    missile: createSvgImage(missileSvg)
};

/**
 * MOTOR DEL JUEGO
 */
const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');
const ui = {
    hud: document.getElementById('hud'),
    score: document.getElementById('score'),
    lives: document.getElementById('lives'),
    startScreen: document.getElementById('startScreen'),
    gameOverScreen: document.getElementById('gameOverScreen'),
    finalScore: document.getElementById('finalScore'),
    startBtn: document.getElementById('startBtn'),
    restartBtn: document.getElementById('restartBtn')
};

// Estado Global
let gameState = 'MENU'; // MENU, PLAYING, GAMEOVER
let score = 0;
let lives = 3;
let frameCount = 0;
let screenShakeTime = 0;

// Listas de entidades
let player;
let enemies = [];
let bullets = [];
let enemyBullets = [];
let particles = [];
let clouds = [];

// Controles
const keys = {
    ArrowUp: false, ArrowDown: false, ArrowLeft: false, ArrowRight: false,
    w: false, a: false, s: false, d: false, Space: false
};
let mouse = { x: canvas.width / 2, y: canvas.height - 100, isDown: false };
let useMouse = false;

// Configuración de controles del teclado
window.addEventListener('keydown', e => {
    if(keys.hasOwnProperty(e.key)) keys[e.key] = true;
    if(e.key === ' ') keys.Space = true;
    useMouse = false;
});
window.addEventListener('keyup', e => {
    if(keys.hasOwnProperty(e.key)) keys[e.key] = false;
    if(e.key === ' ') keys.Space = false;
});

// Configuración de controles táctiles/ratón
function getMousePos(evt) {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    return {
        x: (evt.clientX - rect.left) * scaleX,
        y: (evt.clientY - rect.top) * scaleY
    };
}

canvas.addEventListener('mousemove', e => {
    mouse = getMousePos(e);
    useMouse = true;
});
canvas.addEventListener('touchmove', e => {
    e.preventDefault(); // Prevenir scroll
    mouse = getMousePos(e.touches[0]);
    useMouse = true;
}, {passive: false});

// Botones UI
ui.startBtn.addEventListener('click', startGame);
ui.restartBtn.addEventListener('click', startGame);

/**
 * CLASES
 */
class Player {
    constructor() {
        this.width = 70;
        this.height = 70;
        this.x = canvas.width / 2 - this.width / 2;
        this.y = canvas.height - this.height - 30;
        this.speed = 6;
        this.cooldown = 0;
        this.invulnerable = 0;
    }

    update() {
        if (useMouse) {
            // Interpolar suavemente hacia el ratón
            this.x += (mouse.x - this.width/2 - this.x) * 0.15;
            this.y += (mouse.y - this.height/2 - this.y) * 0.15;
        } else {
            if (keys.ArrowLeft || keys.a) this.x -= this.speed;
            if (keys.ArrowRight || keys.d) this.x += this.speed;
            if (keys.ArrowUp || keys.w) this.y -= this.speed;
            if (keys.ArrowDown || keys.s) this.y += this.speed;
        }

        // Límites de pantalla
        this.x = Math.max(0, Math.min(canvas.width - this.width, this.x));
        this.y = Math.max(0, Math.min(canvas.height - this.height, this.y));

        // Disparo automático rápido
        if (this.cooldown > 0) this.cooldown--;
        if (this.cooldown === 0) {
            bullets.push(new Bullet(this.x + this.width / 2, this.y));
            // Disparo doble si el score es alto
            if(score > 1000) {
                bullets.push(new Bullet(this.x + 10, this.y + 20));
                bullets.push(new Bullet(this.x + this.width - 10, this.y + 20));
            }
            this.cooldown = 12;
        }

        if (this.invulnerable > 0) this.invulnerable--;
    }

    draw() {
        // Parpadeo cuando es invulnerable
        if (this.invulnerable > 0 && Math.floor(Date.now() / 100) % 2 === 0) return;
        
        // Efecto de inclinación al moverse lateralmente
        ctx.save();
        ctx.translate(this.x + this.width/2, this.y + this.height/2);
        
        let tilt = 0;
        if(useMouse) {
            tilt = (mouse.x - this.width/2 - this.x) * 0.05;
        } else {
            if(keys.ArrowLeft || keys.a) tilt = -10;
            if(keys.ArrowRight || keys.d) tilt = 10;
        }
        // Limitar la inclinación
        tilt = Math.max(-15, Math.min(15, tilt));
        
        ctx.rotate(tilt * Math.PI / 180);
        ctx.drawImage(assets.player, -this.width/2, -this.height/2, this.width, this.height);
        ctx.restore();
    }
}

class Bullet {
    constructor(x, y) {
        this.x = x;
        this.y = y;
        this.radius = 4;
        this.speed = 15;
    }
    update() { this.y -= this.speed; }
    draw() {
        ctx.fillStyle = '#FEF08A';
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fill();
        ctx.fillStyle = '#FFF';
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius/2, 0, Math.PI * 2);
        ctx.fill();
    }
}

class Enemy {
    constructor() {
        this.width = 65;
        this.height = 65;
        this.x = Math.random() * (canvas.width - this.width);
        this.y = -this.height;
        this.speed = 2 + Math.random() * 2 + (score / 1000); // Se vuelve más rápido
        this.hp = 2 + Math.floor(score / 2000); // Más vida con el tiempo
        this.shootTimer = Math.floor(Math.random() * 60) + 60;
    }
    update() {
        this.y += this.speed;
        
        // Movimiento sinusoidal ligero
        this.x += Math.sin(frameCount * 0.05 + this.y) * 1.5;
        this.x = Math.max(0, Math.min(canvas.width - this.width, this.x));

        this.shootTimer--;
        if (this.shootTimer <= 0) {
            enemyBullets.push(new EnemyMissile(this.x + this.width / 2, this.y + this.height));
            this.shootTimer = 80 + Math.random() * 60;
        }
    }
    draw() {
        ctx.drawImage(assets.enemy, this.x, this.y, this.width, this.height);
    }
}

class EnemyMissile {
    constructor(x, y) {
        this.width = 12;
        this.height = 30;
        this.x = x - this.width/2;
        this.y = y;
        this.speed = 6 + (score / 1500);
    }
    update() { this.y += this.speed; }
    draw() {
        ctx.drawImage(assets.missile, this.x, this.y, this.width, this.height);
    }
}

class Particle {
    constructor(x, y, color) {
        this.x = x;
        this.y = y;
        this.vx = (Math.random() - 0.5) * 10;
        this.vy = (Math.random() - 0.5) * 10;
        this.life = 1.0;
        this.decay = Math.random() * 0.05 + 0.02;
        this.color = color;
        this.size = Math.random() * 5 + 2;
    }
    update() {
        this.x += this.vx;
        this.y += this.vy;
        this.life -= this.decay;
    }
    draw() {
        ctx.globalAlpha = this.life;
        ctx.fillStyle = this.color;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1.0;
    }
}

class Cloud {
    constructor() {
        this.x = Math.random() * canvas.width;
        this.y = -150;
        this.size = Math.random() * 80 + 40;
        this.speed = (Math.random() * 1 + 0.5);
        this.opacity = Math.random() * 0.5 + 0.3;
    }
    update() {
        this.y += this.speed;
        if(gameState === 'PLAYING') this.y += this.speed; // Se mueven más rápido jugando
    }
    draw() {
        ctx.fillStyle = `rgba(255, 255, 255, ${this.opacity})`;
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI*2);
        ctx.arc(this.x + this.size*0.8, this.y + this.size*0.2, this.size*0.8, 0, Math.PI*2);
        ctx.arc(this.x - this.size*0.8, this.y + this.size*0.2, this.size*0.8, 0, Math.PI*2);
        ctx.fill();
    }
}

/**
 * FUNCIONES AUXILIARES
 */
function createExplosion(x, y, color) {
    for (let i = 0; i < 20; i++) {
        let pColor = color || (Math.random() > 0.5 ? '#EF4444' : '#F59E0B');
        particles.push(new Particle(x, y, pColor));
    }
    // Añadir humo
    for (let i = 0; i < 10; i++) {
        particles.push(new Particle(x, y, '#4B5563'));
    }
    screenShakeTime = 10;
}

function checkCollision(rect1, rect2) {
    // Tolerancia para cajas de colisión más justas
    const margin = 10; 
    return (
        rect1.x + margin < rect2.x + rect2.width - margin &&
        rect1.x + rect1.width - margin > rect2.x + margin &&
        rect1.y + margin < rect2.y + rect2.height - margin &&
        rect1.y + rect1.height - margin > rect2.y + margin
    );
}

function checkCircleRect(circleX, circleY, radius, rect) {
    let testX = circleX;
    let testY = circleY;

    if (circleX < rect.x) testX = rect.x;
    else if (circleX > rect.x + rect.width) testX = rect.x + rect.width;
    
    if (circleY < rect.y) testY = rect.y;
    else if (circleY > rect.y + rect.height) testY = rect.y + rect.height;

    let distX = circleX - testX;
    let distY = circleY - testY;
    let distance = Math.sqrt((distX*distX) + (distY*distY));

    return distance <= radius;
}

/**
 * FLUJO DEL JUEGO
 */
function startGame() {
    player = new Player();
    enemies = [];
    bullets = [];
    enemyBullets = [];
    particles = [];
    score = 0;
    lives = 3;
    frameCount = 0;
    gameState = 'PLAYING';
    
    ui.score.innerText = score;
    ui.lives.innerText = lives;
    
    ui.startScreen.classList.add('hidden');
    ui.gameOverScreen.classList.add('hidden');
    ui.hud.classList.remove('hidden');
    
    // Reposicionar el ratón al centro
    mouse = { x: canvas.width/2, y: canvas.height - 100 };
}

function gameOver() {
    gameState = 'GAMEOVER';
    ui.finalScore.innerText = score;
    ui.hud.classList.add('hidden');
    ui.gameOverScreen.classList.remove('hidden');
    createExplosion(player.x + player.width/2, player.y + player.height/2);
}

/**
 * BUCLE PRINCIPAL
 */
function update() {
    frameCount++;

    // Generar nubes siempre
    if (frameCount % 60 === 0) clouds.push(new Cloud());
    
    clouds.forEach((cloud, i) => {
        cloud.update();
        if(cloud.y > canvas.height + 100) clouds.splice(i, 1);
    });

    if (gameState === 'PLAYING') {
        player.update();

        // Generar enemigos
        let spawnRate = Math.max(30, 90 - Math.floor(score / 50)); // Más rápido entre más puntos
        if (frameCount % spawnRate === 0) {
            enemies.push(new Enemy());
        }

        // Actualizar Balas Jugador
        bullets.forEach((b, i) => {
            b.update();
            if (b.y < -10) bullets.splice(i, 1);
        });

        // Actualizar Misiles Enemigos
        enemyBullets.forEach((eb, i) => {
            eb.update();
            if (eb.y > canvas.height) enemyBullets.splice(i, 1);
            
            // Colisión Misil -> Jugador
            if (player.invulnerable <= 0 && checkCollision({x: eb.x, y: eb.y, width: eb.width, height: eb.height}, player)) {
                enemyBullets.splice(i, 1);
                lives--;
                ui.lives.innerText = lives;
                createExplosion(player.x + player.width/2, player.y + player.height/2, '#F87171');
                player.invulnerable = 60; // 1 segundo de invulnerabilidad
                if (lives <= 0) gameOver();
            }
        });

        // Actualizar Enemigos
        enemies.forEach((enemy, i) => {
            enemy.update();
            if (enemy.y > canvas.height) {
                enemies.splice(i, 1);
                // Penalización por dejar pasar enemigos
                score = Math.max(0, score - 10);
                ui.score.innerText = score;
            }

            // Colisión Enemigo -> Jugador (Choque)
            if (player.invulnerable <= 0 && checkCollision(enemy, player)) {
                enemies.splice(i, 1);
                createExplosion(enemy.x + enemy.width/2, enemy.y + enemy.height/2);
                lives--;
                ui.lives.innerText = lives;
                player.invulnerable = 90;
                if (lives <= 0) gameOver();
            }

            // Colisión Bala Jugador -> Enemigo
            bullets.forEach((b, j) => {
                if (checkCircleRect(b.x, b.y, b.radius, enemy)) {
                    enemy.hp--;
                    bullets.splice(j, 1);
                    createExplosion(b.x, b.y, '#FCD34D'); // Chispas
                    
                    if (enemy.hp <= 0) {
                        enemies.splice(i, 1);
                        createExplosion(enemy.x + enemy.width/2, enemy.y + enemy.height/2);
                        score += 100;
                        ui.score.innerText = score;
                    }
                }
            });
        });
    }

    // Actualizar partículas
    particles.forEach((p, i) => {
        p.update();
        if (p.life <= 0) particles.splice(i, 1);
    });
}

function draw() {
    // Efecto Screen Shake
    ctx.save();
    if (screenShakeTime > 0) {
        const dx = (Math.random() - 0.5) * 10;
        const dy = (Math.random() - 0.5) * 10;
        ctx.translate(dx, dy);
        screenShakeTime--;
    }

    // Limpiar Canvas
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    // Dibujar fondo (las nubes)
    clouds.forEach(c => c.draw());

    if (gameState === 'PLAYING' || gameState === 'GAMEOVER') {
        if(gameState === 'PLAYING') player.draw();
        bullets.forEach(b => b.draw());
        enemyBullets.forEach(eb => eb.draw());
        enemies.forEach(e => e.draw());
        particles.forEach(p => p.draw());
    }

    ctx.restore();
}

function gameLoop() {
    update();
    draw();
    requestAnimationFrame(gameLoop);
}

// Iniciar animaciones de fondo (nubes) en el menú
for(let i=0; i<10; i++) {
    let c = new Cloud();
    c.y = Math.random() * canvas.height;
    clouds.push(c);
}
gameLoop();

</script>
</body>
</html>
